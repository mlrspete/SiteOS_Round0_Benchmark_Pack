{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SiteOS Round 0 independent blind review",
  "type": "object",
  "additionalProperties": false,
  "required": ["candidateCode", "reviewer", "reviewedAt", "visual", "code", "confidence", "notes"],
  "properties": {
    "candidateCode": {"type": "string", "pattern": "^C-[0-9]{4}$"},
    "reviewer": {"type": "string", "minLength": 1},
    "reviewedAt": {"type": "string", "format": "date-time"},
    "visual": {"type": "number", "minimum": 0, "maximum": 20},
    "code": {"type": "number", "minimum": 0, "maximum": 10},
    "confidence": {"enum": ["low", "medium", "high"]},
    "notes": {"type": "string"}
  }
}
