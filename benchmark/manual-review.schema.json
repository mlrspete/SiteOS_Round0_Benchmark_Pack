{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SiteOS Round 0 adjudicated manual score",
  "type": "object",
  "required": ["modelSlug", "visual", "code", "verification", "efficiency", "reviewers"],
  "properties": {
    "modelSlug": {"type": "string"},
    "visual": {"type": "number", "minimum": 0, "maximum": 20},
    "code": {"type": "number", "minimum": 0, "maximum": 10},
    "verification": {"type": "number", "minimum": 0, "maximum": 5},
    "efficiency": {"type": "number", "minimum": 0, "maximum": 5},
    "reviewers": {"type": "array", "minItems": 2, "items": {"type": "string"}},
    "adjudicationNotes": {"type": "string"}
  }
}
