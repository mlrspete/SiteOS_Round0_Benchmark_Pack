{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SiteOS Round 0 run record",
  "type": "object",
  "required": ["runId", "modelSlug", "candidateCode", "runPosition", "gateway", "requestedModelId", "expectedCanonicalSlug", "harnessModel", "status", "promptSha256", "starterSha256"],
  "properties": {
    "runId": {"type": "string"},
    "modelSlug": {"type": "string"},
    "candidateCode": {"type": "string", "pattern": "^C-[0-9]{4}$"},
    "runPosition": {"type": "integer", "minimum": 1, "maximum": 14},
    "gateway": {"const": "OpenRouter"},
    "requestedModelId": {"type": "string"},
    "expectedCanonicalSlug": {"type": "string"},
    "harnessModel": {"type": "string"},
    "variant": {"type": ["string", "null"]},
    "resolvedModelId": {"type": ["string", "null"]},
    "resolvedCanonicalSlug": {"type": ["string", "null"]},
    "providerRequestId": {"type": ["string", "null"]},
    "routerMetadata": {"type": "array"},
    "startedAt": {"type": ["string", "null"]},
    "finishedAt": {"type": ["string", "null"]},
    "status": {"enum": ["prepared", "running", "completed", "failed", "timed-out", "invalid"]},
    "promptSha256": {"type": "string"},
    "starterSha256": {"type": "string"},
    "elapsedMs": {"type": ["integer", "null"]},
    "inputTokens": {"type": ["integer", "null"]},
    "outputTokens": {"type": ["integer", "null"]},
    "cachedTokens": {"type": ["integer", "null"]},
    "reportedCostUsd": {"type": ["number", "null"]},
    "exitCode": {"type": ["integer", "null"]},
    "interventions": {"type": "integer", "minimum": 0},
    "commandsObserved": {"type": "array", "items": {"type": "string"}},
    "toolNamesObserved": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
